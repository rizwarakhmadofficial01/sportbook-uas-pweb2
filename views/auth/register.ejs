<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - SportBook</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="auth-wrap">
    <div class="auth-card">
      <h1>Buat Akun</h1>
      <p class="sub">Daftar sebagai pengguna untuk mulai booking lapangan.</p>

      <% if (successMsg && successMsg.length) { %><div class="alert alert-success"><%= successMsg[0] %></div><% } %>
      <% if (errorMsg && errorMsg.length) { %><div class="alert alert-error"><%= errorMsg[0] %></div><% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <label>Nama Lengkap</label>
          <input type="text" name="name" placeholder="Nama kamu" required>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="nama@email.com" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="Minimal 6 karakter" required>
        </div>
        <div class="form-group">
          <label>Konfirmasi Password</label>
          <input type="password" name="confirm_password" placeholder="Ulangi password" required>
        </div>
        <button class="btn btn-primary btn-block" type="submit">Daftar</button>
      </form>

      <div class="switch">Sudah punya akun? <a href="/login">Login di sini</a></div>
    </div>
  </div>
</body>
</html>
