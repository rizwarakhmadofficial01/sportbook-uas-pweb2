<%- include('../partials/header') %>

<div class="page-title">Booking: <%= field.name %></div>
<div class="page-subtitle"><%= field.category %> · Rp <%= field.price_per_hour.toLocaleString('id-ID') %> / jam</div>

<div class="card" style="max-width: 560px;">
  <form action="/user/fields/<%= field.id %>/book" method="POST">
    <div class="form-group">
      <label>Tanggal Booking</label>
      <input type="date" name="booking_date" required>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Jam Mulai</label>
        <input type="time" name="start_time" required>
      </div>
      <div class="form-group">
        <label>Jam Selesai</label>
        <input type="time" name="end_time" required>
      </div>
    </div>
    <div class="form-group">
      <label>Catatan (opsional)</label>
      <textarea name="notes" rows="2" placeholder="Contoh: butuh bola tambahan"></textarea>
    </div>
    <div style="display:flex; gap:10px;">
      <button class="btn btn-primary" type="submit">Konfirmasi Booking</button>
      <a href="/user/fields" class="btn btn-outline">Batal</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
