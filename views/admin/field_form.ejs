<%- include('../partials/header') %>

<div class="page-title"><%= title %></div>
<div class="page-subtitle">Isi detail lapangan olahraga di bawah ini.</div>

<div class="card" style="max-width: 560px;">
  <form action="<%= field ? '/admin/fields/' + field.id + '?_method=PUT' : '/admin/fields' %>" method="POST">
    <div class="form-group">
      <label>Nama Lapangan</label>
      <input type="text" name="name" value="<%= field ? field.name : '' %>" required>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Kategori</label>
        <select name="category" required>
          <% ['Futsal','Badminton','Basket','Tenis','Voli'].forEach(c => { %>
            <option value="<%= c %>" <%= field && field.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Harga per Jam (Rp)</label>
        <input type="number" name="price_per_hour" value="<%= field ? field.price_per_hour : '' %>" min="0" required>
      </div>
    </div>
    <div class="form-group">
      <label>Deskripsi</label>
      <textarea name="description" rows="3"><%= field ? field.description : '' %></textarea>
    </div>
    <div class="form-group">
      <label>URL Gambar (opsional)</label>
      <input type="text" name="image_url" value="<%= field ? field.image_url : '' %>" placeholder="/images/futsal.jpg">
    </div>
    <% if (field) { %>
      <div class="form-group">
        <label><input type="checkbox" name="is_active" value="1" <%= field.is_active ? 'checked' : '' %> style="width:auto; margin-right:6px;">Lapangan Aktif (dapat dibooking)</label>
      </div>
    <% } %>
    <div style="display:flex; gap:10px;">
      <button class="btn btn-primary" type="submit">Simpan</button>
      <a href="/admin/fields" class="btn btn-outline">Batal</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
