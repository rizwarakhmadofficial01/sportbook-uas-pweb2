<%- include('../partials/header') %>

<div class="page-title">Daftar Pengguna</div>
<div class="page-subtitle">Seluruh akun yang terdaftar di SportBook.</div>

<table>
  <thead><tr><th>Nama</th><th>Email</th><th>Role</th><th>Terdaftar</th></tr></thead>
  <tbody>
    <% users.forEach(u => { %>
      <tr>
        <td><%= u.name %></td>
        <td><%= u.email %></td>
        <td><span class="badge <%= u.role === 'admin' ? 'badge-confirmed' : 'badge-completed' %>"><%= u.role %></span></td>
        <td><%= u.created_at %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>
